---
import Layout from '../layouts/Layout.astro';
import { tools } from '../tools';
---

<Layout>
  <h1>Tools</h1>
  <p class="lead">A small collection of personal web tools. All static, no accounts, no tracking.</p>

  {
    tools.length === 0 ? (
      <p class="empty">No tools yet. Add one in <code>src/tools.ts</code>.</p>
    ) : (
      <ul class="tool-list">
        {tools.map((tool) => (
          <li>
            <a href={`/${tool.slug}/`}>
              <span class="title">{tool.title}</span>
              <span class="desc">{tool.description}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</Layout>

<style>
  h1 {
    margin: 0 0 0.5rem;
  }
  .lead {
    color: var(--fg-muted);
    margin: 0 0 2rem;
  }
  .empty {
    color: var(--fg-muted);
  }
  .tool-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }
  .tool-list a {
    display: block;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--fg);
    text-decoration: none;
    transition: border-color 0.15s ease;
  }
  .tool-list a:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .title {
    display: block;
    font-weight: 600;
  }
  .desc {
    display: block;
    color: var(--fg-muted);
    font-size: 0.925rem;
    margin-top: 0.25rem;
  }
</style>
