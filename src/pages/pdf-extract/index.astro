---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="PDF文本提取"
  description="仅在浏览器内从PDF提取文本并下载的工具"
  lang="zh-CN"
>
  <h1>PDF文本提取</h1>
  <p class="lead">
    选择PDF文件后，将在浏览器内提取文本并下载为 <code>.txt</code>。
    文件不会被上传到任何服务器。
  </p>

  <p class="sample">
    📎 用于测试：<a href="/pdf-extract/sample.pdf" download>下载示例PDF</a>
  </p>

  <label class="drop-zone" id="drop-zone">
    <input id="pdf-input" type="file" accept="application/pdf" />
    <span class="drop-zone-content">
      <span class="drop-zone-icon">📄</span>
      <span class="drop-zone-text">点击选择或拖拽 PDF 文件</span>
      <span class="drop-zone-hint">支持 .pdf 格式</span>
    </span>
    <span class="drop-zone-file" id="file-name" hidden></span>
  </label>

  <p id="status" class="status" role="status" aria-live="polite"></p>

  <div id="progress-container" class="progress-container" hidden>
    <div
      id="progress-bar"
      class="progress-bar"
      role="progressbar"
      aria-valuenow="0"
      aria-valuemin="0"
      aria-valuemax="100"
    >
      <span id="progress-text" class="progress-text" aria-hidden="true">0%</span>
    </div>
  </div>

  <a id="download" class="download-btn" hidden download>下载提取结果 (.txt)</a>

  <div id="chinese-warning" class="chinese-warning" hidden>
    <div class="chinese-warning-icon">⚠️</div>
    <div class="chinese-warning-content">
      <h3>中文提取可能不完整</h3>
      <p>检测到提取的文本中中文字符比例异常低，可能存在以下情况：</p>
      <ul>
        <li><strong>嵌入字体编码问题</strong>：PDF使用了特殊编码的嵌入字体，导致中文无法正确解析</li>
        <li><strong>字体未正确嵌入</strong>：PDF创建时字体信息丢失或损坏</li>
      </ul>
      <p><strong>建议尝试：</strong></p>
      <ul>
        <li>使用其他PDF阅读器（如Adobe Acrobat）打开并重新导出</li>
        <li>如果是您自己生成的PDF，请确保在导出时选择"嵌入所有字体"或使用标准字体</li>
        <li>尝试使用OCR工具识别PDF中的文字</li>
      </ul>
    </div>
  </div>

  <details id="debug-panel" class="debug-panel" hidden>
    <summary>调试信息</summary>
    <div id="debug-content" class="debug-content"></div>
  </details>
</Layout>

<script>
  import * as pdfjsLib from 'pdfjs-dist';
  // Vite-specific: produces a module Worker constructor bundled at build time.
  import PdfWorker from 'pdfjs-dist/build/pdf.worker.min.mjs?worker';
  import {
    assemblePageText,
    normalizeText,
    formatPageBlock,
    joinPages,
    countCharTypes,
    checkFontWarnings,
    analyzeChineseExtraction,
    type TextItem,
    type DebugInfo,
    type FontInfo,
    type PageDebugInfo,
  } from './_lib/text-processing';

  pdfjsLib.GlobalWorkerOptions.workerPort = new PdfWorker();

  const input = document.getElementById('pdf-input') as HTMLInputElement;
  const status = document.getElementById('status') as HTMLParagraphElement;
  const download = document.getElementById('download') as HTMLAnchorElement;
  const dropZone = document.getElementById('drop-zone') as HTMLLabelElement;
  const fileName = document.getElementById('file-name') as HTMLSpanElement;
  const dropZoneContent = dropZone.querySelector('.drop-zone-content') as HTMLSpanElement;
  const progressContainer = document.getElementById('progress-container') as HTMLDivElement;
  const progressBar = document.getElementById('progress-bar') as HTMLDivElement;
  const progressText = document.getElementById('progress-text') as HTMLSpanElement;
  const debugPanel = document.getElementById('debug-panel') as HTMLDetailsElement;
  const debugContent = document.getElementById('debug-content') as HTMLDivElement;
  const chineseWarning = document.getElementById('chinese-warning') as HTMLDivElement;

  let currentObjectUrl: string | null = null;
  let extractionStartTime: number | null = null;

  // Drag-and-drop events
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });

  dropZone.addEventListener('dragleave', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const files = e.dataTransfer?.files;
    const file = files?.[0];
    if (file) {
      if (file.type === 'application/pdf') {
        input.files = files;
        input.dispatchEvent(new Event('change'));
      } else {
        setStatus('error', '请选择 PDF 文件');
      }
    }
  });

  function setStatus(type: 'loading' | 'success' | 'error', text: string) {
    status.textContent = text;
    status.className = 'status';
    if (type !== 'loading') {
      status.classList.add(`status--${type}`);
    }
  }

  function formatElapsedTime(ms: number): string {
    const seconds = Math.round(ms / 1000);
    if (seconds < 60) {
      return `${seconds}秒`;
    }
    const minutes = Math.floor(seconds / 60);
    const remainingSeconds = seconds % 60;
    return `${minutes}分${remainingSeconds}秒`;
  }

  function setProgress(percent: number, pagesProcessed?: number, elapsedMs?: number) {
    progressBar.style.width = `${percent}%`;
    progressBar.setAttribute('aria-valuenow', String(percent));

    let displayText = `${percent}%`;

    // Show pages per second for meaningful measurements (at least 2 pages and 500ms)
    if (pagesProcessed !== undefined && elapsedMs !== undefined && pagesProcessed >= 2 && elapsedMs >= 500) {
      const pagesPerSecond = (pagesProcessed / (elapsedMs / 1000)).toFixed(1);
      displayText = `${percent}% · ${pagesPerSecond}页/秒`;
    }

    progressText.textContent = displayText;
  }

  function setIndeterminate(show: boolean) {
    if (show) {
      progressBar.classList.add('progress-bar--indeterminate');
      progressBar.removeAttribute('aria-valuenow');
      progressText.textContent = '';
    } else {
      progressBar.classList.remove('progress-bar--indeterminate');
    }
  }

  function showProgress() {
    progressContainer.hidden = false;
    extractionStartTime = Date.now();
    setProgress(0);
  }

  function hideProgress() {
    progressContainer.hidden = true;
    extractionStartTime = null;
  }

  function updateFileDisplay(file: File) {
    fileName.textContent = file.name;
    fileName.hidden = false;
    dropZoneContent.hidden = true;
  }

  function resetFileDisplay() {
    fileName.hidden = true;
    dropZoneContent.hidden = false;
  }

  function renderDebugInfo(debugInfo: DebugInfo) {
    let html = '';

    // Warnings section (if any)
    if (debugInfo.warnings.length > 0) {
      html += '<div class="debug-section debug-section--warning">';
      html += '<h4>警告</h4>';
      html += '<ul>';
      for (const warning of debugInfo.warnings) {
        html += `<li>${warning}</li>`;
      }
      html += '</ul></div>';
    }

    // Fonts section
    html += '<div class="debug-section">';
    html += '<h4>检测到的字体</h4>';
    if (debugInfo.fonts.length === 0) {
      html += '<p>未检测到字体</p>';
    } else {
      html += '<ul>';
      for (const font of debugInfo.fonts) {
        html += `<li><code>${font.name}</code> (${font.type})</li>`;
      }
      html += '</ul>';
    }
    html += '</div>';

    // Character statistics
    const totalPages = debugInfo.pages.length;
    const totalTextItems = debugInfo.pages.reduce((sum, p) => sum + p.textItemCount, 0);
    const totalChinese = debugInfo.pages.reduce((sum, p) => sum + p.chineseCount, 0);
    const totalEnglish = debugInfo.pages.reduce((sum, p) => sum + p.englishCount, 0);
    const totalDigits = debugInfo.pages.reduce((sum, p) => sum + p.digitCount, 0);
    const totalOther = debugInfo.pages.reduce((sum, p) => sum + p.otherCount, 0);

    html += '<div class="debug-section">';
    html += '<h4>字符统计</h4>';
    html += '<table><tbody>';
    html += `<tr><td>总页数</td><td>${totalPages}</td></tr>`;
    html += `<tr><td>总 TextItem 数</td><td>${totalTextItems}</td></tr>`;
    html += `<tr><td>中文字符</td><td>${totalChinese}</td></tr>`;
    html += `<tr><td>英文字母</td><td>${totalEnglish}</td></tr>`;
    html += `<tr><td>数字</td><td>${totalDigits}</td></tr>`;
    html += `<tr><td>其他字符</td><td>${totalOther}</td></tr>`;
    html += '</tbody></table>';
    html += '</div>';

    // Per-page details (collapsible)
    html += '<details class="debug-section">';
    html += '<summary>每页详细信息</summary>';
    html += '<table><thead><tr><th>页</th><th>TextItem</th><th>中文</th><th>英文</th><th>数字</th><th>其他</th></tr></thead><tbody>';
    for (const page of debugInfo.pages) {
      html += `<tr><td>${page.pageNum}</td><td>${page.textItemCount}</td><td>${page.chineseCount}</td><td>${page.englishCount}</td><td>${page.digitCount}</td><td>${page.otherCount}</td></tr>`;
    }
    html += '</tbody></table>';
    html += '</details>';

    debugContent.innerHTML = html;
    debugPanel.hidden = false;
  }

  function hideDebugPanel() {
    debugPanel.hidden = true;
    debugContent.innerHTML = '';
  }

  function showChineseWarning(show: boolean) {
    chineseWarning.hidden = !show;
  }

  input.addEventListener('change', async () => {
    const file = input.files?.[0];
    if (!file) return;

    updateFileDisplay(file);

    if (currentObjectUrl) {
      URL.revokeObjectURL(currentObjectUrl);
      currentObjectUrl = null;
    }
    download.hidden = true;
    download.removeAttribute('href');
    hideDebugPanel();
    showChineseWarning(false);
    setStatus('loading', '正在解析PDF文件...');
    showProgress();
    setIndeterminate(true);

    try {
      const buf = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({
        data: buf,
        cMapUrl: '/pdf-extract/cmaps/',
        cMapPacked: true,
        standardFontDataUrl: '/pdf-extract/standard_fonts/',
      }).promise;

      setIndeterminate(false);
      const pageBlocks: string[] = [];

      // Debug info collection
      const debugInfo: DebugInfo = {
        fonts: [],
        pages: [],
        warnings: [],
      };
      const seenFonts = new Set<string>();

      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
        const elapsedMs = extractionStartTime ? Date.now() - extractionStartTime : 0;
        const elapsedText = elapsedMs >= 1000 ? ` · 已用时: ${formatElapsedTime(elapsedMs)}` : '';
        setStatus('loading', `提取中：第 ${pageNum} / ${pdf.numPages} 页${elapsedText}`);

        const percent = Math.round((pageNum / pdf.numPages) * 100);
        setProgress(percent, pageNum, elapsedMs);

        const page = await pdf.getPage(pageNum);
        const content = await page.getTextContent();
        const items = content.items.filter((item) => 'str' in item) as TextItem[];

        // Collect font info from content.styles
        const styles = content.styles as Record<string, { fontFamily: string }>;
        for (const [fontId, style] of Object.entries(styles)) {
          if (!seenFonts.has(fontId)) {
            seenFonts.add(fontId);
            const fontName = style.fontFamily || fontId;
            const fontInfo: FontInfo = {
              name: fontName,
              type: fontId.includes('+') ? 'embedded' : 'standard',
            };
            debugInfo.fonts.push(fontInfo);

            // Check for warnings
            const warnings = checkFontWarnings(fontName);
            debugInfo.warnings.push(...warnings);
          }
        }

        // Collect page stats
        const pageText = assemblePageText(items);
        const charCounts = countCharTypes(pageText);
        const pageDebugInfo: PageDebugInfo = {
          pageNum,
          textItemCount: items.length,
          chineseCount: charCounts.chinese,
          englishCount: charCounts.english,
          digitCount: charCounts.digits,
          otherCount: charCounts.other,
        };
        debugInfo.pages.push(pageDebugInfo);

        const normalizedText = normalizeText(pageText);
        pageBlocks.push(formatPageBlock(pageNum, normalizedText));
      }

      const text = joinPages(pageBlocks);
      const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
      currentObjectUrl = URL.createObjectURL(blob);
      download.href = currentObjectUrl;
      download.download = file.name.replace(/\.pdf$/i, '') + '.txt';
      download.hidden = false;

      // Show debug info
      renderDebugInfo(debugInfo);

      // Check for Chinese extraction issues and show warning if needed
      const chineseAnalysis = analyzeChineseExtraction(debugInfo.pages);
      showChineseWarning(chineseAnalysis.hasIssue);

      const totalElapsedMs = extractionStartTime ? Date.now() - extractionStartTime : 0;
      const timeText = totalElapsedMs >= 1000 ? `，用时 ${formatElapsedTime(totalElapsedMs)}` : '';
      hideProgress();
      setStatus('success', `完成（共 ${pdf.numPages} 页${timeText}）`);
    } catch (e) {
      hideProgress();
      setStatus('error', `错误：${e instanceof Error ? e.message : String(e)}`);
      resetFileDisplay();
    }
  });
</script>

<style>
  h1 {
    margin: 0 0 0.5rem;
  }
  .lead {
    color: var(--fg-muted);
    margin: 0 0 1.5rem;
  }
  .sample {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
  }
  .sample a {
    color: var(--accent);
  }

  /* Drop Zone */
  .drop-zone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    padding: 2rem;
    border: 2px dashed var(--border);
    border-radius: 8px;
    cursor: pointer;
    text-align: center;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    margin: 0 0 1rem;
  }
  .drop-zone:hover,
  .drop-zone.drag-over {
    border-color: var(--accent);
    background-color: rgba(37, 99, 235, 0.05);
  }
  @media (prefers-color-scheme: dark) {
    .drop-zone:hover,
    .drop-zone.drag-over {
      background-color: rgba(96, 165, 250, 0.05);
    }
  }
  .drop-zone input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .drop-zone-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .drop-zone-icon {
    font-size: 2rem;
    line-height: 1;
  }
  .drop-zone-text {
    color: var(--fg);
    font-size: 1rem;
  }
  .drop-zone-hint {
    color: var(--fg-muted);
    font-size: 0.875rem;
  }
  .drop-zone-file {
    color: var(--fg);
    font-size: 0.925rem;
    word-break: break-all;
  }

  /* Status */
  .status {
    min-height: 1.6em;
    font-size: 0.925rem;
    color: var(--fg-muted);
    margin: 0 0 1rem;
  }
  .status--success {
    color: var(--color-success);
  }
  .status--error {
    color: var(--color-error);
  }

  /* Progress Bar */
  .progress-container {
    width: 100%;
    max-width: 400px;
    height: 24px;
    background-color: var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin: 0 0 1rem;
  }
  .progress-container[hidden] {
    display: none;
  }
  .progress-bar {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: width 0.2s ease;
    min-width: 5rem;
  }
  .progress-bar--indeterminate {
    width: 100%;
    background: linear-gradient(
      90deg,
      var(--border) 0%,
      var(--accent) 50%,
      var(--border) 100%
    );
    background-size: 200% 100%;
    animation: indeterminate 1.5s ease-in-out infinite;
  }
  @keyframes indeterminate {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
  .progress-text {
    color: var(--bg);
    font-size: 0.75rem;
    font-weight: 600;
  }

  /* Download Button */
  .download-btn {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background: var(--accent);
    color: var(--bg);
    border-radius: 6px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .download-btn:hover {
    opacity: 0.9;
    text-decoration: none;
  }
  .download-btn[hidden] {
    display: none;
  }

  /* Chinese Warning */
  .chinese-warning {
    display: flex;
    gap: 1rem;
    margin: 1.5rem 0;
    padding: 1rem;
    background: rgba(234, 179, 8, 0.1);
    border: 1px solid rgba(234, 179, 8, 0.4);
    border-radius: 8px;
  }
  .chinese-warning[hidden] {
    display: none;
  }
  .chinese-warning-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .chinese-warning-content {
    flex: 1;
  }
  .chinese-warning h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: #b45309;
  }
  @media (prefers-color-scheme: dark) {
    .chinese-warning h3 {
      color: #fbbf24;
    }
  }
  .chinese-warning p {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
  }
  .chinese-warning p:last-child {
    margin-bottom: 0;
  }
  .chinese-warning ul {
    margin: 0 0 0.75rem;
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
  }
  .chinese-warning ul:last-child {
    margin-bottom: 0;
  }
  .chinese-warning li {
    margin: 0.25rem 0;
  }
  .chinese-warning strong {
    color: var(--fg);
  }

  /* Debug Panel */
  .debug-panel {
    margin: 1.5rem 0 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.875rem;
  }
  .debug-panel[hidden] {
    display: none;
  }
  .debug-panel summary {
    padding: 0.75rem 1rem;
    cursor: pointer;
    font-weight: 500;
    color: var(--fg-muted);
    user-select: none;
  }
  .debug-panel summary:hover {
    color: var(--fg);
  }
  .debug-content {
    padding: 0 1rem 1rem;
  }
  .debug-section {
    margin: 0 0 1rem;
  }
  .debug-section:last-child {
    margin-bottom: 0;
  }
  .debug-section h4 {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--fg);
  }
  .debug-section--warning {
    background: rgba(234, 179, 8, 0.1);
    border: 1px solid rgba(234, 179, 8, 0.3);
    border-radius: 4px;
    padding: 0.75rem;
  }
  .debug-section--warning h4 {
    color: #b45309;
  }
  @media (prefers-color-scheme: dark) {
    .debug-section--warning h4 {
      color: #fbbf24;
    }
  }
  .debug-section ul {
    margin: 0;
    padding-left: 1.25rem;
  }
  .debug-section li {
    margin: 0.25rem 0;
    color: var(--fg-muted);
  }
  .debug-section code {
    font-size: 0.8125rem;
  }
  .debug-section table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }
  .debug-section th,
  .debug-section td {
    padding: 0.375rem 0.5rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }
  .debug-section th {
    font-weight: 600;
    color: var(--fg-muted);
  }
  .debug-section td {
    color: var(--fg);
  }
  .debug-section td:first-child {
    color: var(--fg-muted);
  }
  .debug-section details {
    margin: 0;
  }
  .debug-section details summary {
    padding: 0.5rem 0;
    cursor: pointer;
    font-weight: 500;
    color: var(--fg-muted);
  }

  /* Mobile adjustments */
  @media (max-width: 639px) {
    .drop-zone {
      padding: 1.5rem;
      min-height: 100px;
    }
    .download-btn {
      width: 100%;
      max-width: 280px;
      text-align: center;
    }
  }
</style>
