---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="PDF文本提取"
  description="仅在浏览器内从PDF提取文本并下载的工具"
  lang="zh-CN"
>
  <h1>PDF文本提取</h1>
  <p class="lead">
    选择PDF文件后，将在浏览器内提取文本并下载为 <code>.txt</code>。
    文件不会被上传到任何服务器。
  </p>

  <p class="sample">
    📎 用于测试：<a href="/pdf-extract/sample.pdf" download>下载示例PDF</a>
  </p>

  <label class="drop-zone" id="drop-zone">
    <input id="pdf-input" type="file" accept="application/pdf" />
    <span class="drop-zone-content">
      <span class="drop-zone-icon">📄</span>
      <span class="drop-zone-text">点击选择或拖拽 PDF 文件</span>
      <span class="drop-zone-hint">支持 .pdf 格式</span>
    </span>
    <span class="drop-zone-file" id="file-name" hidden></span>
  </label>

  <p id="status" class="status" role="status" aria-live="polite"></p>

  <a id="download" class="download-btn" hidden download>下载提取结果 (.txt)</a>
</Layout>

<script>
  import * as pdfjsLib from 'pdfjs-dist';
  // Vite-specific: produces a module Worker constructor bundled at build time.
  import PdfWorker from 'pdfjs-dist/build/pdf.worker.min.mjs?worker';
  import {
    assemblePageText,
    normalizeText,
    formatPageBlock,
    joinPages,
    type TextItem,
  } from './_lib/text-processing';

  pdfjsLib.GlobalWorkerOptions.workerPort = new PdfWorker();

  const input = document.getElementById('pdf-input') as HTMLInputElement;
  const status = document.getElementById('status') as HTMLParagraphElement;
  const download = document.getElementById('download') as HTMLAnchorElement;
  const dropZone = document.getElementById('drop-zone') as HTMLLabelElement;
  const fileName = document.getElementById('file-name') as HTMLSpanElement;
  const dropZoneContent = dropZone.querySelector('.drop-zone-content') as HTMLSpanElement;

  let currentObjectUrl: string | null = null;

  // Drag-and-drop events
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });

  dropZone.addEventListener('dragleave', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      const file = files[0];
      if (file.type === 'application/pdf') {
        input.files = files;
        input.dispatchEvent(new Event('change'));
      } else {
        setStatus('error', '请选择 PDF 文件');
      }
    }
  });

  function setStatus(type: 'loading' | 'success' | 'error', text: string) {
    status.textContent = text;
    status.className = 'status';
    if (type !== 'loading') {
      status.classList.add(`status--${type}`);
    }
  }

  function updateFileDisplay(file: File) {
    fileName.textContent = file.name;
    fileName.hidden = false;
    dropZoneContent.hidden = true;
  }

  function resetFileDisplay() {
    fileName.hidden = true;
    dropZoneContent.hidden = false;
  }

  input.addEventListener('change', async () => {
    const file = input.files?.[0];
    if (!file) return;

    updateFileDisplay(file);

    if (currentObjectUrl) {
      URL.revokeObjectURL(currentObjectUrl);
      currentObjectUrl = null;
    }
    download.hidden = true;
    download.removeAttribute('href');
    setStatus('loading', '加载中…');

    try {
      const buf = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: buf }).promise;
      const pageBlocks: string[] = [];

      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
        setStatus('loading', `提取中：第 ${pageNum} / ${pdf.numPages} 页`);
        const page = await pdf.getPage(pageNum);
        const content = await page.getTextContent();
        const items: TextItem[] = content.items.filter(
          (item): item is TextItem => 'str' in item
        );
        const pageText = normalizeText(assemblePageText(items));
        pageBlocks.push(formatPageBlock(pageNum, pageText));
      }

      const text = joinPages(pageBlocks);
      const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
      currentObjectUrl = URL.createObjectURL(blob);
      download.href = currentObjectUrl;
      download.download = file.name.replace(/\.pdf$/i, '') + '.txt';
      download.hidden = false;
      setStatus('success', `完成（共 ${pdf.numPages} 页）`);
    } catch (e) {
      setStatus('error', `错误：${e instanceof Error ? e.message : String(e)}`);
      resetFileDisplay();
    }
  });
</script>

<style>
  h1 {
    margin: 0 0 0.5rem;
  }
  .lead {
    color: var(--fg-muted);
    margin: 0 0 1.5rem;
  }
  .sample {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
  }
  .sample a {
    color: var(--accent);
  }

  /* Drop Zone */
  .drop-zone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    padding: 2rem;
    border: 2px dashed var(--border);
    border-radius: 8px;
    cursor: pointer;
    text-align: center;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    margin: 0 0 1rem;
  }
  .drop-zone:hover,
  .drop-zone.drag-over {
    border-color: var(--accent);
    background-color: rgba(37, 99, 235, 0.05);
  }
  @media (prefers-color-scheme: dark) {
    .drop-zone:hover,
    .drop-zone.drag-over {
      background-color: rgba(96, 165, 250, 0.05);
    }
  }
  .drop-zone input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .drop-zone-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .drop-zone-icon {
    font-size: 2rem;
    line-height: 1;
  }
  .drop-zone-text {
    color: var(--fg);
    font-size: 1rem;
  }
  .drop-zone-hint {
    color: var(--fg-muted);
    font-size: 0.875rem;
  }
  .drop-zone-file {
    color: var(--fg);
    font-size: 0.925rem;
    word-break: break-all;
  }

  /* Status */
  .status {
    min-height: 1.6em;
    font-size: 0.925rem;
    color: var(--fg-muted);
    margin: 0 0 1rem;
  }
  .status--success {
    color: var(--color-success);
  }
  .status--error {
    color: var(--color-error);
  }

  /* Download Button */
  .download-btn {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background: var(--accent);
    color: var(--bg);
    border-radius: 6px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .download-btn:hover {
    opacity: 0.9;
    text-decoration: none;
  }
  .download-btn[hidden] {
    display: none;
  }

  /* Mobile adjustments */
  @media (max-width: 639px) {
    .drop-zone {
      padding: 1.5rem;
      min-height: 100px;
    }
    .download-btn {
      width: 100%;
      max-width: 280px;
      text-align: center;
    }
  }
</style>
