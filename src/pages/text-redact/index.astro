---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="敏感信息掩蔽"
  description="在浏览器内对文本进行脱敏处理，文件不会上传到任何服务器"
  lang="zh-CN"
>
  <h1>敏感信息掩蔽</h1>
  <p class="lead">
    在浏览器内对文本进行脱敏处理，文件不会上传到任何服务器。
  </p>

  <section class="section">
    <label for="input-text" class="label">原文</label>
    <div class="textarea-wrapper">
      <textarea
        id="input-text"
        class="textarea"
        placeholder="在此粘贴需要脱敏的文本..."
      ></textarea>
      <button id="clear-btn" class="clear-btn" type="button" hidden aria-label="清除文本">×</button>
    </div>
  </section>

  <section class="section">
    <div class="label">掩蔽设置</div>

    <div class="subsection">
      <div class="subsection-label">快捷选项</div>
      <label class="checkbox-label">
        <input type="checkbox" id="mask-numbers" />
        <span class="checkbox-content">
          <span class="checkbox-text">掩蔽数字</span>
          <span class="checkbox-hint">例：1,234,567 → ***</span>
        </span>
      </label>
    </div>

    <div class="subsection">
      <div class="subsection-label">自定义掩蔽词</div>
      <div class="word-input-container">
        <textarea
          id="word-input"
          class="word-input-textarea"
          placeholder="输入要掩蔽的词语，每行一个..."
          rows="3"
        ></textarea>
      </div>
      <div class="word-buttons-row">
        <button type="button" id="add-word-btn" class="btn-secondary">添加</button>
        <button type="button" id="clear-all-btn" class="clear-all-btn" hidden>清除全部</button>
      </div>
      <div id="word-tags-section" class="word-tags-section" hidden>
        <div class="word-tags-header">
          <span id="word-count" class="word-count">已添加 (0)</span>
        </div>
        <div id="word-tags" class="word-tags"></div>
      </div>
      <p id="word-message" class="word-message" hidden role="status" aria-live="polite"></p>
    </div>
  </section>

  <section class="section">
    <label for="output-text" class="label">处理结果</label>
    <div class="output-wrapper">
      <textarea
        id="output-text"
        class="textarea textarea--readonly"
        readonly
        placeholder="（处理后的文本将显示在这里）"
      ></textarea>
      <span id="processing-indicator" class="processing-indicator" aria-label="处理中">
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </span>
    </div>
    <button type="button" id="copy-btn" class="btn-primary" disabled>
      <span id="copy-icon">📋</span>
      <span id="copy-text">复制处理结果</span>
    </button>
  </section>
</Layout>

<script>
  import { redact, type RedactOptions } from './_lib/redact';

  // Constants
  const STORAGE_KEY = 'text-redact-custom-words';

  // Elements
  const inputText = document.getElementById('input-text') as HTMLTextAreaElement;
  const outputText = document.getElementById('output-text') as HTMLTextAreaElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const maskNumbers = document.getElementById('mask-numbers') as HTMLInputElement;
  const wordInput = document.getElementById('word-input') as HTMLTextAreaElement;
  const addWordBtn = document.getElementById('add-word-btn') as HTMLButtonElement;
  const clearAllBtn = document.getElementById('clear-all-btn') as HTMLButtonElement;
  const wordTagsSection = document.getElementById('word-tags-section') as HTMLDivElement;
  const wordTags = document.getElementById('word-tags') as HTMLDivElement;
  const wordCount = document.getElementById('word-count') as HTMLSpanElement;
  const wordMessage = document.getElementById('word-message') as HTMLParagraphElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const copyIcon = document.getElementById('copy-icon') as HTMLSpanElement;
  const copyText = document.getElementById('copy-text') as HTMLSpanElement;
  const processingIndicator = document.getElementById('processing-indicator') as HTMLSpanElement;

  // State
  let customWords: string[] = [];
  let debounceTimer: number | null = null;
  let messageTimer: number | null = null;

  // localStorage helpers
  function saveWords() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(customWords));
    } catch {
      showMessage('存储空间不足，请清理部分词语', 'error');
    }
  }

  function loadWords(): string[] {
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) {
        return JSON.parse(stored);
      }
    } catch {
      showMessage('浏览器存储不可用，词语将在刷新后丢失', 'warning');
    }
    return [];
  }

  function clearStoredWords() {
    try {
      localStorage.removeItem(STORAGE_KEY);
    } catch {
      // Silently ignore
    }
  }

  // Message display helper
  function showMessage(text: string, type: 'success' | 'warning' | 'error' = 'success') {
    if (messageTimer !== null) {
      clearTimeout(messageTimer);
    }
    wordMessage.textContent = text;
    wordMessage.className = `word-message word-message--${type}`;
    wordMessage.hidden = false;
    messageTimer = window.setTimeout(() => {
      wordMessage.hidden = true;
    }, 3000);
  }

  // Dynamic debounce time based on text length
  function getDebounceTime(textLength: number): number {
    if (textLength > 50000) return 500;
    if (textLength > 5000) return 300;
    return 150;
  }

  // Processing indicator helpers
  function showProcessingIndicator() {
    processingIndicator.classList.add('active');
  }

  function hideProcessingIndicator() {
    processingIndicator.classList.remove('active');
  }

  // Debounced processing
  function scheduleProcess() {
    if (debounceTimer !== null) {
      clearTimeout(debounceTimer);
    }
    showProcessingIndicator();
    const debounceTime = getDebounceTime(inputText.value.length);
    debounceTimer = window.setTimeout(processText, debounceTime);
  }

  function processText() {
    const options: RedactOptions = {
      customWords,
      maskNumbers: maskNumbers.checked,
    };

    const result = redact(inputText.value, options);
    outputText.value = result;

    // Update copy button state
    copyBtn.disabled = !result;

    hideProcessingIndicator();
  }

  // Clear button visibility
  function updateClearButton() {
    clearBtn.hidden = !inputText.value;
  }

  // Word tag management
  function addWords() {
    const lines = wordInput.value.split('\n');
    const wordsToAdd: string[] = [];
    let skippedDuplicates = 0;

    for (const line of lines) {
      const trimmed = line.trim();
      if (!trimmed) continue;

      if (customWords.includes(trimmed) || wordsToAdd.includes(trimmed)) {
        skippedDuplicates++;
        continue;
      }

      wordsToAdd.push(trimmed);
    }

    if (wordsToAdd.length === 0 && skippedDuplicates === 0) {
      showMessage('请输入至少一个词语', 'warning');
      return;
    }

    if (wordsToAdd.length === 0 && skippedDuplicates > 0) {
      showMessage('所有词语都已存在', 'warning');
      return;
    }

    customWords.push(...wordsToAdd);
    saveWords();
    renderTags();
    wordInput.value = '';
    scheduleProcess();

    if (skippedDuplicates > 0) {
      showMessage(`已添加 ${wordsToAdd.length} 个词语，跳过 ${skippedDuplicates} 个重复`, 'success');
    } else {
      showMessage(`已添加 ${wordsToAdd.length} 个词语`, 'success');
    }
  }

  function removeWord(word: string) {
    customWords = customWords.filter((w) => w !== word);
    saveWords();
    renderTags();
    scheduleProcess();
  }

  function clearAllWords() {
    if (!confirm('确定要清除所有已保存的掩蔽词吗？此操作无法撤销。')) {
      return;
    }
    customWords = [];
    clearStoredWords();
    renderTags();
    scheduleProcess();
  }

  function renderTags() {
    // Update word tags section visibility
    const hasWords = customWords.length > 0;
    wordTagsSection.hidden = !hasWords;
    clearAllBtn.hidden = !hasWords;

    // Update word count
    wordCount.textContent = `已添加 (${customWords.length})`;

    // Render tags
    wordTags.innerHTML = '';
    for (const word of customWords) {
      const tag = document.createElement('span');
      tag.className = 'tag';
      tag.innerHTML = `${escapeHtml(word)} <button type="button" class="tag-remove" aria-label="移除 ${escapeHtml(word)}">×</button>`;
      tag.querySelector('.tag-remove')!.addEventListener('click', () => removeWord(word));
      wordTags.appendChild(tag);
    }
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Copy functionality
  async function copyResult() {
    try {
      await navigator.clipboard.writeText(outputText.value);
      copyIcon.textContent = '✓';
      copyText.textContent = '已复制';
      setTimeout(() => {
        copyIcon.textContent = '📋';
        copyText.textContent = '复制处理结果';
      }, 1500);
    } catch {
      // Fallback for older browsers
      outputText.select();
      document.execCommand('copy');
    }
  }

  // Event listeners
  inputText.addEventListener('input', () => {
    updateClearButton();
    scheduleProcess();
  });

  clearBtn.addEventListener('click', () => {
    inputText.value = '';
    updateClearButton();
    scheduleProcess();
    inputText.focus();
  });

  maskNumbers.addEventListener('change', scheduleProcess);

  addWordBtn.addEventListener('click', addWords);

  clearAllBtn.addEventListener('click', clearAllWords);

  copyBtn.addEventListener('click', copyResult);

  // Load saved words on init
  customWords = loadWords();
  renderTags();

  // Initial state
  updateClearButton();
  if (customWords.length > 0) {
    scheduleProcess();
  }
</script>

<style>
  h1 {
    margin: 0 0 0.5rem;
  }
  .lead {
    color: var(--fg-muted);
    margin: 0 0 1.5rem;
  }

  .section {
    margin-bottom: 1.5rem;
  }

  .label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .subsection {
    margin-bottom: 1rem;
  }
  .subsection-label {
    font-size: 0.875rem;
    color: var(--fg-muted);
    margin-bottom: 0.5rem;
  }

  /* Textarea */
  .textarea-wrapper {
    position: relative;
  }
  .textarea {
    width: 100%;
    min-height: 150px;
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.925rem;
    line-height: 1.6;
    resize: vertical;
    background: var(--bg);
    color: var(--fg);
  }
  .textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: -1px;
  }
  .textarea--readonly {
    background-color: var(--border);
    cursor: default;
  }

  /* Clear button */
  .clear-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 1.5rem;
    height: 1.5rem;
    border: none;
    background: var(--border);
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    color: var(--fg-muted);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .clear-btn:hover {
    background: var(--fg-muted);
    color: var(--bg);
  }
  .clear-btn[hidden] {
    display: none;
  }

  /* Checkbox */
  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    cursor: pointer;
  }
  .checkbox-label input[type='checkbox'] {
    margin-top: 0.2rem;
    width: 1rem;
    height: 1rem;
    accent-color: var(--accent);
  }
  .checkbox-content {
    display: flex;
    flex-direction: column;
  }
  .checkbox-text {
    color: var(--fg);
  }
  .checkbox-hint {
    font-size: 0.875rem;
    color: var(--fg-muted);
  }

  /* Word input */
  .word-input-container {
    margin-bottom: 0.5rem;
  }
  .word-input-textarea {
    width: 100%;
    min-height: 80px;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.925rem;
    line-height: 1.5;
    resize: vertical;
    background: var(--bg);
    color: var(--fg);
  }
  .word-input-textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: -1px;
  }

  .word-buttons-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .clear-all-btn {
    background: none;
    border: none;
    color: var(--fg-muted);
    font-size: 0.875rem;
    cursor: pointer;
    padding: 0.5rem 0.75rem;
  }
  .clear-all-btn:hover {
    color: var(--color-error);
    text-decoration: underline;
  }
  .clear-all-btn[hidden] {
    display: none;
  }

  /* Word tags section */
  .word-tags-section {
    margin-top: 0.5rem;
  }
  .word-tags-section[hidden] {
    display: none;
  }
  .word-tags-header {
    margin-bottom: 0.5rem;
  }
  .word-count {
    font-size: 0.875rem;
    color: var(--fg-muted);
  }

  /* Word tags */
  .word-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    background: var(--border);
    border-radius: 4px;
    font-size: 0.875rem;
  }
  .tag-remove {
    border: none;
    background: none;
    cursor: pointer;
    opacity: 0.6;
    padding: 0;
    font-size: 1rem;
    line-height: 1;
    color: var(--fg);
  }
  .tag-remove:hover {
    opacity: 1;
  }

  /* Message */
  .word-message {
    font-size: 0.875rem;
    margin: 0.5rem 0 0;
  }
  .word-message[hidden] {
    display: none;
  }
  .word-message--success {
    color: var(--color-success);
  }
  .word-message--warning {
    color: var(--color-warning);
  }
  .word-message--error {
    color: var(--color-error);
  }

  /* Buttons */
  .btn-secondary {
    padding: 0.5rem 1rem;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.925rem;
    cursor: pointer;
  }
  .btn-secondary:hover {
    background: var(--border);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    margin-top: 0.75rem;
  }
  .btn-primary:hover:not(:disabled) {
    opacity: 0.9;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Output wrapper for indicator positioning */
  .output-wrapper {
    position: relative;
  }

  /* Processing indicator */
  .processing-indicator {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: flex;
    gap: 4px;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }
  .processing-indicator.active {
    opacity: 1;
  }
  .processing-indicator .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--fg-muted);
    opacity: 0.3;
  }
  .processing-indicator.active .dot {
    animation: dot-pulse 0.9s infinite;
  }
  .processing-indicator.active .dot:nth-child(2) {
    animation-delay: 0.3s;
  }
  .processing-indicator.active .dot:nth-child(3) {
    animation-delay: 0.6s;
  }

  @keyframes dot-pulse {
    0%, 100% {
      opacity: 0.3;
    }
    33% {
      opacity: 1;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 639px) {
    .btn-primary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
